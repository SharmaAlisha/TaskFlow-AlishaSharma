# App
APP_ENV=development
APP_PORT=8080
APP_HOST=0.0.0.0
APP_BODY_LIMIT_MB=1

# Database
DB_HOST=postgres
DB_PORT=5432
DB_USER=taskflow
DB_PASSWORD=taskflow_secret
DB_NAME=taskflow
DB_SSL_MODE=disable
DB_MAX_CONNS=25
DB_MIN_CONNS=5

# JWT
JWT_SECRET=change-me-to-a-random-64-char-string-in-production
JWT_ACCESS_EXPIRY=24h
JWT_REFRESH_EXPIRY=168h

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate Limiting
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_AUTH_WINDOW=15m
RATE_LIMIT_API_MAX=100
RATE_LIMIT_API_WINDOW=1m

# Webhook
WEBHOOK_MAX_RETRIES=3
WEBHOOK_TIMEOUT=10s
WEBHOOK_WORKER_POOL_SIZE=10

# Seeding (set to true for first run)
SEED_DB=true

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
